{{#with page.versions}}
<div class="page-versions">
<button class="version-menu-toggle" title="Show other versions of page">
  {{@root.page.componentVersion.displayVersion}}
</button>
<div class="version-menu">
  {{#each .}}
  {{#unless missing}}
  <a class="version{{#if (eq version @root.page.componentVersion.version)}} is-current{{/if}}"
     href="{{relativize url}}">{{displayVersion}}</a>
  {{/unless}}
  {{/each}}
</div>
</div>
{{/with}}
